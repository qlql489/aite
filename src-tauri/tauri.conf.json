{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aite",
  "version": "0.1.1",
  "identifier": "com.zengjinlong.aite",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:cli",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "10.13",
      "hardenedRuntime": true,
      "entitlements": "./Entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdGRjA4QkQwNkMxRkU3OEMKUldTTTV4OXMwSXZ3ZjFTNlpBQkhGMXJSWWYvVllZVEprR0tvQUVVMmhRVnVyaXplNG1wa0xLUkYK",
      "endpoints": [
        "https://github.com/qlql489/aite/releases/latest/download/latest.json"
      ]
    }
  }
}
